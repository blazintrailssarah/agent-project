# ===========================
# CrewAI runtime artifacts
# ===========================
# Workspace files generated during reviews
.crewai/workspace/*.txt
.crewai/workspace/*.json
.crewai/workspace/*.md
.crewai/workspace/trace/*.log
.crewai/workspace/trace/*.txt
.crewai/workspace/trace/*.json
.crewai/*.log
.crewai/ci_summary.json
.crewai/workspace/trace/

# Keep workspace directory structure
!.crewai/workspace/.gitkeep
!.crewai/workspace/trace/.gitkeep

# Memory files ARE tracked (version-controlled review memory)
# .crewai/memory/memory.json     — tracked
# .crewai/memory/suppressions.json — tracked

